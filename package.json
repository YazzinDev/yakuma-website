{
  "name": "yakuma-website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate:legal-dates": "node scripts/generate-legal-document-dates.mjs",
    "predev": "npm run generate:legal-dates",
    "dev": "vite",
    "robots": "node scripts/generate-robots.mjs",
